{
    "name": "candypilled",
    "version": "0.1.0",
    "private": true,
    "scripts": {
        "dev": "next dev",
        "build": "next build",
        "start": "next start",
        "lint": "npx eslint",
        "format": "prettier --write .",
        "gen:component": "tsx src/lib/scripts/generators/generateComponent.ts",
        "gen:class": "tsx src/lib/scripts/generators/generateClass.ts",
        "gen:icon": "tsx src/lib/scripts/generators/generateIcon.ts",
        "prepare": "husky"
    },
    "lint-staged": {
        "*.{js,jsx,ts,tsx}": [
            "eslint --fix",
            "prettier --write"
        ],
        "*.{json,md,scss,css}": [
            "prettier --write"
        ],
        "*.scss": [
            "stylelint --fix"
        ]
    },
    "dependencies": {
        "@ianvs/prettier-plugin-sort-imports": "^4.7.1",
        "husky": "^9.1.7",
        "lint-staged": "^16.4.0",
        "next": "16.2.10",
        "prettier": "^3.9.5",
        "react": "19.2.4",
        "react-dom": "19.2.4",
        "sass": "^1.101.0",
        "stylelint": "^17.14.0",
        "stylelint-config-standard-scss": "^17.0.0",
        "stylelint-order": "^8.1.1",
        "tsx": "^4.23.0"
    },
    "devDependencies": {
        "@types/node": "^20",
        "@types/react": "^19",
        "@types/react-dom": "^19",
        "eslint": "^9",
        "eslint-config-next": "16.2.10",
        "typescript": "^5"
    }
}
